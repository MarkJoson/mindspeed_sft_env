+def _cached_chunk_indices(cu_seqlens, chunk_size):
+    """tolist()+prepare_chunk_indices computed once/step, cached on the cu_seqlens tensor object
+    (same object across all GDN layers; fresh tensor next step -> auto-invalidates). Avoids the
+    ~Nx redundant .tolist() D2H syncs/step that the profile showed cost ~3s/step."""
