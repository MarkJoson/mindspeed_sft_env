--- /dev/null
+++ b/mindspeed_mm/fsdp/features/memory/chunkloss/fused_lm_ce_maxsum.py
@@ -0,0 +1,52 @@
+# Truly-fused linear-CE via torch_npu with_max_sum ops (fused backward, no grad_logits materialized).
+# Forward op: fused_cross_entropy_loss_with_max_sum ; backward op: fused_linear_cross_entropy_loss_with_max_sum_grad.
+import torch
+
+
+class FusedChunkLMLossMaxSum(torch.autograd.Function):
+    @staticmethod
+    def forward(ctx, hidden_states, head_weight, head_bias, loss_kwargs_chunks, chunk_size):
+        if head_bias is not None:
+            raise NotImplementedError("head_bias not supported")
+        grad_inputs = torch.empty_like(hidden_states)
+        grad_weight = torch.zeros_like(head_weight)
+        acc = torch.zeros((), device=hidden_states.device)
+        gi_chunks = torch.split(grad_inputs, chunk_size, dim=1)
+        h_chunks = torch.split(hidden_states, chunk_size, dim=1)
+        V = head_weight.size(0)
+        for h_c, gi_c, kw in zip(h_chunks, gi_chunks, loss_kwargs_chunks):
+            ign = kw["ignore_index"]; alpha = kw["alpha"]
+            sl = kw["shift_labels"].reshape(-1)
+            h2d = h_c.reshape(-1, h_c.size(-1))
+            # forward preprocessing (single partition [0,V)); the [c,V] logits are transient
+            logits = torch.nn.functional.linear(h2d, head_weight).float()
+            logits_max = logits.max(dim=-1).values
+            tmask = (sl == ign)
+            masked_target = sl.clone(); masked_target[tmask] = 0
+            shifted = logits - logits_max.unsqueeze(-1)
+            ar = torch.arange(h2d.size(0), device=h2d.device)
+            predicted = shifted[ar, masked_target] * (~tmask)
+            sum_exp = torch.exp(shifted).sum(dim=-1)
+            del logits, shifted
+            loss_vec, _ = torch.ops.npu.fused_cross_entropy_loss_with_max_sum(logits_max, sum_exp, predicted)
+            acc += (loss_vec * (~tmask)).sum() / alpha
+            # fused backward: produces grad_input [c,H] + grad_weight [V,H] directly (no grad_logits)
+            grad_loss = ((~tmask).to(torch.float32) / alpha)
+            gi, gw = torch.ops.npu.fused_linear_cross_entropy_loss_with_max_sum_grad(
+                grad_loss, h2d, head_weight, tmask, masked_target, 0.0,
+                logits_max=logits_max, sum_exp_logits=sum_exp)
+            gi_c.copy_(gi.to(hidden_states.dtype).view_as(gi_c))
+            grad_weight.add_(gw.to(head_weight.dtype))
+        ctx.save_for_backward(grad_inputs, grad_weight)
+        return acc
+
+    @staticmethod
+    def backward(ctx, grad_output):
+        gi, gw = ctx.saved_tensors
+        if not torch.equal(grad_output, torch.ones_like(grad_output)):
+            gi = gi * grad_output; gw = gw * grad_output
+        return gi, gw, None, None, None
+
+
+def fused_chunk_lm_loss_maxsum(hidden_states, head_weight, head_bias, loss_kwargs_chunks, chunk_size):
+    return FusedChunkLMLossMaxSum.apply(hidden_states, head_weight, head_bias, loss_kwargs_chunks, chunk_size)
