+        return cached[1], cached[2]
+    cu_list = cu_seqlens.tolist()
+    chunk_indices = prepare_chunk_indices(cu_list, chunk_size)
+    try:
+        cu_seqlens._gdn_ci_cache = (chunk_size, cu_list, chunk_indices)
+    except Exception:
+        pass
+    return cu_list, chunk_indices
